linters: linters_with_defaults(
    line_length_linter = line_length_linter(120),
    indentation_linter = indentation_linter(2),
    # "symbols" permits the idiomatic `.` throwaway callback parameter (function(.)).
    object_name_linter = object_name_linter(styles = c("snake_case", "SNAKE_CASE", "CamelCase", "symbols")),
    # Functions accepted as a valid exit under return_style = "explicit". The
    # census domain aborters are terminals like base abort().
    return_linter = return_linter(
      return_style = "explicit",
      return_functions = c("abort", "cli_abort", "abort_census_error", "abort_census_validation_error")
    ),
    # lintr's default 30 - long descriptive names are fine.
    object_length_linter = object_length_linter(length = 50L),
    # Off: the house `# File:` header on every source file and the inline `code`
    # spans in roxygen blocks are both false-flagged as commented-out code.
    commented_code_linter = NULL
  )
exclusions: list(
    "renv/activate.R",
    "packages/*/renv/",
    "scripts/",
    # roxyassert writes this; never lint generated code.
    "R/contracts-generated.R"
  )
